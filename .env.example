# ────────────────────────────────────────────────────────────
# CEG4195 Lab 2 – Environment Variables  (Secrets Injection)
# ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# ⚠️  NEVER commit .env to version control – it is in .gitignore

# Optional API key  (leave empty to disable authentication)
API_KEY=your-secret-api-key-here
SECRET_TOKEN=your-secret-token-here

# Model
MODEL_PATH=models/unet_house_seg.pth

# Flask
FLASK_DEBUG=false
PORT=5000
LOG_LEVEL=INFO

# Inference
MAX_IMAGE_SIZE=1024
